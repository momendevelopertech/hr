{
  "name": "sphinx-hr-system",
  "version": "1.0.0",
  "private": true,
  "description": "SPHINX Enterprise HR Management System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:push": "cd apps/api && ../../node_modules/.bin/prisma db push",
    "db:generate": "cd apps/api && ../../node_modules/.bin/prisma generate",
    "db:seed": "cd apps/api && ../../node_modules/.bin/ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "turbo": "^1.13.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
