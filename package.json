{
  "name": "sphinx-hr-system",
  "version": "1.0.0",
  "private": true,
  "description": "SPHINX Enterprise HR Management System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:push": "npm --prefix apps/api run prisma:push",
    "db:generate": "npm --prefix apps/api run prisma:generate",
    "db:seed": "npm --prefix apps/api run prisma:seed"
  },
  "devDependencies": {
    "turbo": "^1.13.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@9.4.0"
}
