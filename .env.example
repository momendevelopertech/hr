# ─── DATABASE ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:npg_8CLHWQAGyd0z@ep-spring-moon-adxs7317-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── REDIS ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT (RS256) ─────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ─── CLOUDINARY ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── WHATSAPP (WHAPI) ────────────────────────────────────────────────────────
WHAPI_TOKEN="your_whapi_token"
WHAPI_BASE_URL="https://gate.whapi.cloud/"

# ─── EMAIL ───────────────────────────────────────────────────────────────────
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="your_email@gmail.com"
MAIL_PASS="your_app_password"
MAIL_FROM="SPHINX HR <noreply@sphinx.com>"

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# ─── CSRF ────────────────────────────────────────────────────────────────────
CSRF_SECRET="change_this_to_a_random_secret_string_at_least_32_chars"

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
