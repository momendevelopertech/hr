# DATABASE
# Local Postgres example:
# DATABASE_URL="postgresql://sphinx:sphinxpass@localhost:5432/sphinxhr?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# REDIS
# Local Redis example: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# JWT (RS256)
# In production these two keys are required.
# For local development, if empty and NODE_ENV!=production, the API auto-generates temporary keys.
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
# Optional: base64-encoded PEM keys (useful for Vercel env vars)
JWT_PRIVATE_KEY_
JWT_PUBLIC_KEY_
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# WHATSAPP (WHAPI)
WHAPI_TOKEN=""
WHAPI_BASE_URL="https://gate.whapi.cloud/"

# EMAIL
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER=""
MAIL_PASS=""
MAIL_FROM="SPHINX HR <noreply@sphinx.com>"

# APP
NODE_ENV="development"
API_PORT=3001
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
# PROD URLs (uncomment when switching to server)
# FRONTEND_URL="https://hr-web-ten.vercel.app"
# NEXT_PUBLIC_API_URL="https://hr-api-six.vercel.app/api"
# NEXT_PUBLIC_SOCKET_URL="https://hr-api-six.vercel.app"

# CSRF
CSRF_SECRET="change_this_to_a_random_secret_string_at_least_32_chars"

# RATE LIMITING
THROTTLE_TTL=60
THROTTLE_LIMIT=100
