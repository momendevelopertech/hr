# DATABASE
# Local Postgres example:
# DATABASE_URL="postgresql://sphinx:sphinxpass@localhost:5432/sphinxhr?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# REDIS
# Local Redis example: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# JWT (RS256)
# In production these two keys are required.
# For local development, if empty and NODE_ENV!=production, the API auto-generates temporary keys.
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
# Optional: base64-encoded PEM keys (useful for env vars that don't support newlines).
# If both are provided, *_B64 take precedence over plain PEM values.
JWT_PRIVATE_KEY_B64=""
JWT_PUBLIC_KEY_B64=""
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
REFRESH_TOKEN_SECRET=""

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# WHATSAPP (EVOLUTION API)
EVOLUTION_API_BASE_URL="http://YOUR_VPS_IP:8080"
EVOLUTION_API_KEY=""
EVOLUTION_API_TIMEOUT_MS=10000

# EMAIL
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER=""
MAIL_PASS=""
MAIL_FROM="SPHINX HR <noreply@sphinx.com>"

# APP
NODE_ENV="development"
API_PORT=3001
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="https://hr-api-six.vercel.app/api"
NEXT_PUBLIC_PUSHER_KEY="0fb7606e8df92ee810a0"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"
# Pusher server credentials
PUSHER_APP_ID="2126553"
PUSHER_KEY="0fb7606e8df92ee810a0"
PUSHER_SECRET="6a3507827b2a92c46af8"
PUSHER_CLUSTER="eu"

# CSRF
CSRF_SECRET="change_this_to_a_random_secret_string_at_least_32_chars"

# RATE LIMITING
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# REPORTS CACHE
REPORTS_CACHE_TTL=60
